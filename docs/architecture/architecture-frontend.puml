@startuml Qalam — Frontend Architecture
!theme plain
skinparam defaultFontName Helvetica
skinparam backgroundColor #FAFAFA
skinparam ArrowColor #444444
skinparam ArrowThickness 1.5
skinparam componentStyle rectangle

title Qalam Frontend — Internal Architecture\n(SvelteKit 5 · Svelte-Query · Generated API client)

' ── Routes layer ──────────────────────────────────────────────────────────────
package "Routes  [src/routes/]" #E3F2FD {
    component "+layout.svelte\n+layout.ts" as layout
    component "/ (home)" as routeHome

    package "roots/" #D6EAF8 {
        component "+page (list)" as routeRootList
        component "[id]/+page (detail)" as routeRootDetail
        component "new/+page" as routeRootNew
    }
    package "texts/" #D6EAF8 {
        component "+page (list)" as routeTextList
        component "[id]/+page (detail)" as routeTextDetail
        component "new/+page" as routeTextNew
    }
    package "words/" #D6EAF8 {
        component "+page (list)" as routeWordList
        component "[id]/+page (detail)" as routeWordDetail
        component "new/+page" as routeWordNew
    }
}

' ── Components layer ──────────────────────────────────────────────────────────
package "Components  [src/lib/components/]" #E8F5E9 {
    package "Domain components" #D5F5E3 {
        component "RootForm" as cmpRootForm

        component "TextForm\nFullTextPanel" as cmpText
        component "SentenceEditor\nInterlinearSentence" as cmpSentence
        component "TokenEditor · TokenGrid\nStaleTokenBanner" as cmpToken

        component "WordForm\nAiExamples\nDictionaryLinks" as cmpWord
    }

    package "UI primitives  [ui/]  (shadcn-svelte, owned)" #C8E6C9 {
        component "Button · Badge\nCard · Input\n…" as cmpUI
    }

    package "Styles  [src/styles/]" #C8E6C9 {
        component "tokens · base · arabic\nlayout · components · utilities\nword · root · text · lists · home\nforms · training · annotations\neditors · ai · error\nsemantic · animations" as styles
    }
}

' ── Stores layer ──────────────────────────────────────────────────────────────
package "Stores  [src/lib/stores/]  — server state via @tanstack/svelte-query" #FFF8E1 {
    component "roots.ts\nuseAllRoots() · useRoot(id)\nuseCreateRoot() · useUpdateRoot()\nuseDeleteRoot() · useNormalizeRoot()" as storeRoots

    component "texts.ts\nuseTexts(filters) · useText(id)\nuseSentences(textId)\nuseCreateText/Sentence()\nuseAutoTokenize() · useTransliterateSentence()\nuseReorderSentences() · useReplaceTokens()" as storeTexts

    component "words.ts\nuseWords() · useWord(id)\nuseCreateWord() · useUpdateWord()\nuseDeleteWord()" as storeWords
}

note right of storeRoots
  Query key hierarchy:
  ['roots', 'all']
  ['roots', id]
  ['words', 'forRoot', rootId]
  ['texts', 'all', filters]
  ['texts', id, 'sentences']

  Mutations invalidate
  related query keys on success.
end note

' ── API layer ─────────────────────────────────────────────────────────────────
package "API client  [src/lib/api/]  — generated, never hand-written" #FCE4EC {
    component "sdk.gen.ts\n(typed operation functions\nlistRoots · createText\nautoTokenize · …)" as apiSdk

    component "types.gen.ts\n(request / response types)" as apiTypes

    component "client.gen.ts\n(@hey-api/client-fetch\nbase URL · headers)" as apiClient
}

note bottom of apiSdk
  Generated by:
  pnpm generate:types
  ← GET /api/v1/openapi.json
  (backend must be running)
end note

' ── Backend (external) ────────────────────────────────────────────────────────
cloud "Backend\nKtor REST API\n/api/v1/" as backend

' ── Dependency arrows ─────────────────────────────────────────────────────────

' Routes → Components (via props)
routeRootList   --> cmpRootForm   : props
routeRootDetail --> cmpRootForm   : props
routeTextList   --> cmpText       : props
routeTextDetail --> cmpText       : props
routeTextDetail --> cmpSentence   : props
routeTextDetail --> cmpToken      : props
routeWordList   --> cmpWord       : props
routeWordDetail --> cmpWord       : props

' Routes → Stores (read state + trigger mutations)
routeRootList   --> storeRoots  : useAllRoots()
routeRootDetail --> storeRoots  : useRoot(id)
routeTextList   --> storeTexts  : useTexts(filters)
routeTextDetail --> storeTexts  : useText(id)\nuseSentences(id)
routeWordList   --> storeWords  : useWords()
routeWordDetail --> storeWords  : useWord(id)

' Components → Stores (mutation callbacks, passed down as props)
cmpRootForm --> storeRoots  : useCreateRoot()\nuseUpdateRoot()
cmpText     --> storeTexts  : useCreateText()\nuseUpdateText()
cmpSentence --> storeTexts  : useCreateSentence()\nuseUpdateSentence()
cmpToken    --> storeTexts  : useAutoTokenize()\nuseReplaceTokens()
cmpWord     --> storeWords  : useCreateWord()\nuseUpdateWord()

' Stores → API
storeRoots  --> apiSdk
storeTexts  --> apiSdk
storeWords  --> apiSdk

' API → backend
apiSdk    --> apiClient
apiSdk    --> apiTypes
apiClient --> backend : HTTP (proxied via\nTraefik in Docker\nor Vite in dev)

' UI is consumed by all domain components
cmpRootForm --> cmpUI
cmpText     --> cmpUI
cmpSentence --> cmpUI
cmpToken    --> cmpUI
cmpWord     --> cmpUI

@enduml
