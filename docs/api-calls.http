### Qalam API — sentence & tokenization workflow
### IntelliJ HTTP Client format
### Usage: open in IntelliJ/RustRover, set the "local" environment, run requests in order.

@host = http://localhost:8085
@contentType = application/json

# -----------------------------------------------------------------------
# Copy IDs from responses into these variables as you work through a text.
# -----------------------------------------------------------------------
@textId     = REPLACE_WITH_TEXT_ID
@sentenceId = REPLACE_WITH_SENTENCE_ID
@wordId     = REPLACE_WITH_WORD_ID
@annotationId = REPLACE_WITH_ANNOTATION_ID

###############################################################################
# 0. HEALTH CHECK
###############################################################################

# Quick smoke-test before doing anything else.
### Health check
GET {{host}}/health
Accept: {{contentType}}


###############################################################################
# 1. TEXTS
###############################################################################

# Create a new text. body = full Arabic source (can be long-form).
# Copy the returned `id` into @textId above.
### Create text
POST {{host}}/api/v1/texts
Content-Type: {{contentType}}

{
  "title": "من رواية نجيب محفوظ — زقاق المدق",
  "body": "كانت الحياة في زقاق المدق حياةً هادئةً في ظاهرها، مضطربةً في باطنها. وكان الزقاق يحتضن أسراره كما تحتضن الأم أطفالها.",
  "difficulty": "INTERMEDIATE",
  "dialect": "MSA",
  "tags": ["mahfouz", "novel", "prose"],
  "comments": "Excerpt from Midaq Alley — good for relative clauses and kāna + nominal sentences."
}

###

# Retrieve the full text to verify and get sentence list later.
### Get text by ID
GET {{host}}/api/v1/texts/{{textId}}
Accept: {{contentType}}

###

# Update metadata — add a translation or fix difficulty.
### Update text metadata
PUT {{host}}/api/v1/texts/{{textId}}
Content-Type: {{contentType}}

{
  "translation": "Life in Midaq Alley was quiet on the surface, turbulent beneath. The alley sheltered its secrets the way a mother shelters her children.",
  "difficulty": "INTERMEDIATE"
}

###

# Browse texts — useful to find an ID you forgot to copy.
### List texts (search)
GET {{host}}/api/v1/texts?q=زقاق&page=1&size=10
Accept: {{contentType}}


###############################################################################
# 2. SENTENCES — adding content sentence by sentence
###############################################################################

# Add the first sentence. position is optional — omit to append.
# Copy returned `id` into @sentenceId.
### Add sentence 1
POST {{host}}/api/v1/texts/{{textId}}/sentences
Content-Type: {{contentType}}

{
  "arabicText": "كانت الحياة في زقاق المدق حياةً هادئةً في ظاهرها، مضطربةً في باطنها.",
  "freeTranslation": "Life in Midaq Alley was quiet on the surface, turbulent beneath.",
  "notes": "kāna + nominal predicate; ظاهر/باطن antithesis pair"
}

###

# Add second sentence — explicit position to insert before sentence 1 if needed.
### Add sentence 2
POST {{host}}/api/v1/texts/{{textId}}/sentences
Content-Type: {{contentType}}

{
  "arabicText": "وكان الزقاق يحتضن أسراره كما تحتضن الأم أطفالها.",
  "freeTranslation": "The alley sheltered its secrets the way a mother shelters her children.",
  "notes": "كما comparison clause; iḍāfa chains"
}

###

# Check all sentences are in the right order.
### List sentences for text
GET {{host}}/api/v1/texts/{{textId}}/sentences
Accept: {{contentType}}

###

# Get a single sentence (confirm tokens, transliteration, etc.).
### Get sentence by ID
GET {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}
Accept: {{contentType}}

###

# Fix a typo or add/update a translation/notes after the fact.
# Warning: editing arabicText invalidates existing tokens (tokensValid → false).
### Update sentence
PUT {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}
Content-Type: {{contentType}}

{
  "notes": "kāna + nominal predicate; ظاهر/باطن antithesis — worth an annotation"
}

###

# Drag-and-drop reorder: send all sentence IDs in the desired order.
### Reorder sentences
PUT {{host}}/api/v1/texts/{{textId}}/sentences/reorder
Content-Type: {{contentType}}

{
  "orderedIds": [
    "SENTENCE_UUID_1",
    "SENTENCE_UUID_2"
  ]
}

###

# Remove a sentence you no longer want.
### Delete sentence
DELETE {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}


###############################################################################
# 3. TOKENIZATION — breaking a sentence into alignment tokens
###############################################################################
# Tokens are the interlinear-gloss atoms: arabic fragment + optional
# transliteration + optional gloss + optional link to a vocabulary Word.
# tokensValid on the sentence tells you whether the current tokens match
# the current arabicText.

# --- 3a. AI auto-tokenize (preferred when OPENROUTER_API_KEY is set) ---

# Sends arabicText to AI; returns sentence with tokens populated.
# Requires OPENROUTER_API_KEY in Doppler / env. Returns 503 if not configured.
### Auto-tokenize sentence (AI)
POST {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}/auto-tokenize
Accept: {{contentType}}

###

# --- 3b. Manual token replacement (fallback / correction) ---

# PUT replaces ALL tokens atomically — positions must be contiguous from 1.
# wordId is optional: link to an existing vocabulary word for SRS tracking.
# Use this to correct AI output or when AI is unavailable.
### Replace tokens manually
PUT {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}/tokens
Content-Type: {{contentType}}

{
  "tokens": [
    { "position": 1,  "arabic": "كَانَتْ",    "transliteration": "kānat",    "translation": "was (f.)" },
    { "position": 2,  "arabic": "الْحَيَاةُ", "transliteration": "al-ḥayātu", "translation": "life" },
    { "position": 3,  "arabic": "فِي",        "transliteration": "fī",        "translation": "in" },
    { "position": 4,  "arabic": "زُقَاقِ",    "transliteration": "zuqāqi",    "translation": "alley of" },
    { "position": 5,  "arabic": "الْمِدَقِّ", "transliteration": "al-midaqqi","translation": "the mortar / Midaq" },
    { "position": 6,  "arabic": "حَيَاةً",    "transliteration": "ḥayātan",   "translation": "a life" },
    { "position": 7,  "arabic": "هَادِئَةً",  "transliteration": "hādi'atan", "translation": "quiet (f.)" },
    { "position": 8,  "arabic": "فِي",        "transliteration": "fī",        "translation": "in" },
    { "position": 9,  "arabic": "ظَاهِرِهَا", "transliteration": "ẓāhirihā",  "translation": "its surface/exterior" },
    { "position": 10, "arabic": "مُضْطَرِبَةً","transliteration": "muḍṭaribatan","translation": "turbulent (f.)" },
    { "position": 11, "arabic": "فِي",        "transliteration": "fī",        "translation": "in" },
    { "position": 12, "arabic": "بَاطِنِهَا", "transliteration": "bāṭinihā",  "translation": "its interior/depths" }
  ]
}

###

# Link one token to an existing vocabulary word after the fact.
# Re-PUT the full token list with the wordId filled in for that position.
### Link token to vocabulary word (re-PUT with wordId)
PUT {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}/tokens
Content-Type: {{contentType}}

{
  "tokens": [
    { "position": 1,  "arabic": "كَانَتْ",    "transliteration": "kānat",     "translation": "was (f.)",   "wordId": "{{wordId}}" },
    { "position": 2,  "arabic": "الْحَيَاةُ", "transliteration": "al-ḥayātu", "translation": "life" },
    { "position": 3,  "arabic": "فِي",        "transliteration": "fī",        "translation": "in" }
  ]
}

###

# Wipe tokens entirely — e.g. after editing arabicText, before re-tokenizing.
# The ?confirm=true guard is intentional.
### Clear tokens (destructive)
DELETE {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}/tokens?confirm=true


###############################################################################
# 4. TRANSLITERATION
###############################################################################

# --- 4a. Quick one-off transliteration (rule-based, no AI needed) ---

# Transliterates any Arabic string synchronously using the built-in char map.
# Useful for spot-checking before committing to a sentence.
### Transliterate snippet
POST {{host}}/api/v1/transliterate
Content-Type: {{contentType}}

{
  "arabic": "كانت الحياة في زقاق المدق"
}

###

# --- 4b. AI-generated transliteration for a full sentence ---

# Writes result back to sentence.transliteration. Requires OPENROUTER_API_KEY.
# Use when you want context-aware transliteration (vowel disambiguation, etc.).
### AI transliterate sentence
POST {{host}}/api/v1/texts/{{textId}}/sentences/{{sentenceId}}/transliterate
Accept: {{contentType}}


###############################################################################
# 5. ANNOTATIONS
###############################################################################

# Attach a vocabulary, grammar, cultural, or structural note to any text fragment.
# anchor = the exact Arabic substring being annotated.
### Create annotation (vocabulary)
POST {{host}}/api/v1/texts/{{textId}}/annotations
Content-Type: {{contentType}}

{
  "anchor": "مضطربة",
  "type": "VOCAB",
  "content": "Root ط-ر-ب (ṭrb), Form VIII muftaʿil — in disturbance/turbulence here. Contrast with هادئة (hādi'a, root ه-د-أ).",
  "masteryLevel": "LEARNING",
  "reviewFlag": false
}

###

### Create annotation (grammar)
POST {{host}}/api/v1/texts/{{textId}}/annotations
Content-Type: {{contentType}}

{
  "anchor": "كانت الحياة",
  "type": "GRAMMAR",
  "content": "kāna + mubtada'. The ism of kāna (الحياة) is definite; the xabar (حياةً هادئةً) is indefinite — classic predicate pattern.",
  "reviewFlag": false
}

###

# List all annotations on this text.
### List annotations
GET {{host}}/api/v1/texts/{{textId}}/annotations
Accept: {{contentType}}

###

# Get a specific annotation.
### Get annotation by ID
GET {{host}}/api/v1/texts/{{textId}}/annotations/{{annotationId}}
Accept: {{contentType}}

###

# Link a vocabulary word to an annotation (for SRS cross-referencing).
### Link word to annotation
POST {{host}}/api/v1/texts/{{textId}}/annotations/{{annotationId}}/words
Content-Type: {{contentType}}

{
  "wordId": "{{wordId}}"
}

###

# Update annotation — e.g. bump mastery after reviewing.
### Update annotation mastery
PUT {{host}}/api/v1/texts/{{textId}}/annotations/{{annotationId}}
Content-Type: {{contentType}}

{
  "masteryLevel": "KNOWN",
  "reviewFlag": false
}

###

# Remove a word link without deleting the annotation.
### Remove word link from annotation
DELETE {{host}}/api/v1/texts/{{textId}}/annotations/{{annotationId}}/words/{{wordId}}

###

# Delete the annotation entirely.
### Delete annotation
DELETE {{host}}/api/v1/texts/{{textId}}/annotations/{{annotationId}}


###############################################################################
# 6. VOCABULARY WORDS (quick reference for the content workflow)
###############################################################################

# Look up a word by Arabic text before linking it to a token/annotation.
### Autocomplete word search
GET {{host}}/api/v1/words/autocomplete?q=حياة&limit=5
Accept: {{contentType}}

###

# Create a word you want to track for SRS.
# Copy returned `id` into @wordId to use in token/annotation linking above.
### Create word
POST {{host}}/api/v1/words
Content-Type: {{contentType}}

{
  "arabicText": "مُضْطَرِب",
  "transliteration": "muḍṭarib",
  "translation": "disturbed, turbulent, agitated",
  "partOfSpeech": "ADJECTIVE",
  "dialect": "MSA",
  "difficulty": "INTERMEDIATE"
}

###

# Get a word's full details (rootId, derivedFromId, mastery, etc.).
### Get word by ID
GET {{host}}/api/v1/words/{{wordId}}
Accept: {{contentType}}


###############################################################################
# 7. TYPICAL END-TO-END WORKFLOW (reference order)
###############################################################################
#
#  1. POST /api/v1/texts              → note @textId
#  2. POST /api/v1/texts/{id}/sentences (repeat per sentence) → note @sentenceId
#  3. POST .../sentences/{id}/auto-tokenize
#       OR PUT  .../sentences/{id}/tokens  (manual)
#  4. POST /api/v1/transliterate         (spot-check individual tokens)
#       OR POST .../sentences/{id}/transliterate  (AI, full sentence)
#  5. GET  /api/v1/words/autocomplete    (find word IDs to link)
#  6. PUT  .../sentences/{id}/tokens     (re-PUT with wordId filled in)
#  7. POST .../annotations               (vocab/grammar notes)
#  8. PUT  .../annotations/{id}          (bump mastery over time)
